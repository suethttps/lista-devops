# Copie para .env e preencha com os valores reais.
# O .env NÃO é versionado (está no .gitignore). O Kamal carrega essas
# variáveis automaticamente ao rodar "bin/kamal deploy".

# Senha do PostgreSQL (usada pelo container do banco e pela aplicação).
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Access Token do Docker Hub (Account Settings > Security > New Access Token).
KAMAL_REGISTRY_PASSWORD=seu-docker-hub-access-token
