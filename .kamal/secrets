# Os secrets aqui ficam disponíveis para registry/password, env/secret,
# builder/secrets e accessories/*/env/secret no config/deploy.yml.
#
# NUNCA coloque credenciais cruas neste arquivo — ele é versionado no git.
# Os valores reais ficam no arquivo .env (que está no .gitignore) ou num
# gerenciador de senhas. Aqui só referenciamos variáveis de ambiente.

# Chave mestra do Rails (config/master.key). Não versione o master.key!
RAILS_MASTER_KEY=$(cat config/master.key)

# Token/senha do registry (Docker Hub -> use um Access Token, não a senha).
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Senha do PostgreSQL. O usuário da app ("lista") e o container do banco
# usam a MESMA senha, então as duas variáveis apontam para o mesmo valor.
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
LISTA_DATABASE_PASSWORD=$POSTGRES_PASSWORD
